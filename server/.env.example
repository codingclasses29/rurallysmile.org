# Server
PORT=5000
NODE_ENV=development
MONGO_URI=
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
CLIENT_URL=http://localhost:3000,http://localhost:3001

# Admin login (env fallback + seed)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Trusted Vercel↔Render OTP email relay (same value on both hosts)
OTP_RELAY_SECRET=

# Email — prefer Resend HTTPS on Render free (SMTP ports are blocked there)
RESEND_API_KEY=
RESEND_FROM=Pratibha Khoj 2026 <onboarding@resend.dev>
# Gmail SMTP (works locally / paid Render / Vercel relay)
NODEMAILER_EMAIL=
NODEMAILER_PASSWORD=
CONTACT_ALERT_EMAIL=
EMAIL=
EMAIL_PASSWORD=

# SMS / WhatsApp OTP fallback (Twilio HTTPS — works on Render free)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Gemini AI (admin-only notice drafting)
# IMPORTANT: Never commit a real key. Create a NEW key after revoking any exposed key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Google Sheets (FREE tier) ───────────────────────────────────────────────
# Sheets API is FREE for normal exam-portal usage (thousands of reads/day OK).
#
# RECOMMENDED — Private sheet via Service Account (secure):
# 1) https://console.cloud.google.com → New Project
# 2) Enable FREE API: https://console.cloud.google.com/apis/library/sheets.googleapis.com
# 3) Credentials → Create Service Account → Keys → Add Key → JSON → download
# 4) Save JSON as: server/credentials/google-service-account.json
# 5) Open your Sheet → Share → paste service account email (…@….iam.gserviceaccount.com) → Viewer
# 6) Restart server → Admin → Data Import Center → Sync Now
#
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/google-service-account.json
# Or paste full JSON in one line (Netlify / production):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_SHEET_RANGE=Sheet1!A:Z
GOOGLE_SHEET_DEFAULT_URL=https://docs.google.com/spreadsheets/d/1pe2tcdv1fGwP7o286uQn3Kv-38cu8UZZYWpkxNFWLWs/edit?usp=sharing

# OPTIONAL — API key only works if sheet is public (Anyone with link → Viewer)
# GOOGLE_SHEETS_API_KEY=
