NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Live Render backend
API_PROXY_TARGET=https://rurallysmile-org-4.onrender.com
NEXT_PUBLIC_API_URL=https://rurallysmile-org-4.onrender.com/api/v1

# Required on Vercel for Gmail OTP (Render/Vercel free block SMTP)
MONGO_URI=
EMAIL=
EMAIL_PASSWORD=
# Google Apps Script web app (server/scripts/gmail-otp-webapp.gs) — recommended for live
GMAIL_WEBAPP_URL=
GMAIL_WEBAPP_SECRET=

# Local backend (uncomment while developing against localhost:5000)
# API_PROXY_TARGET=http://localhost:5000
# NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
